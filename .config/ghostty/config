font-family = Inconsolata Nerd Font
font-size = 11
font-feature = -calt, -liga, -dlig

cursor-style-blink = false
cursor-text = #000000

window-padding-x = 4
window-padding-y = 2
window-padding-balance = true

# Always close without confirmation. I use tmux a lot and it gets tedious to
# always have to agree to close Ghostty, especially when tmux allows for a
# process to run after the terminal is closed.
confirm-close-surface = false

# Allow alt + arrow keys for tmux movement.
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+up=unbind
keybind = alt+down=unbind

# Load theme.
config-file = ?theme
