# Font Configuration
font-family = Inconsolata Nerd Font
font-size = 11
font-feature = -calt, -liga, -dlig

# Window Configuration
gtk-single-instance = true
window-decoration = none
gtk-titlebar = false
window-padding-x = 4
window-padding-y = 2
window-padding-balance = true
# background-opacity = 1.0
# background-blur-radius = 32

# Cursor Configuration
# cursor-style = block
# cursor-style-blink = true
# cursor-text = #000000

# Scrollback
scrollback-limit = 100000000

# Terminal features
mouse-hide-while-typing = false
copy-on-select = true
confirm-close-surface = false

# Disable in-app Ghostty toast notifications
# app-notifications = false

# Key bindings for common actions
#keybind = ctrl+c=copy_to_clipboard
#keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size

# Allow alt + arrow keys for tmux movement.
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+up=unbind
keybind = alt+down=unbind

# Drop back to standard legacy xterm sequences so that left/right arrow keys register as tab switch in some apps.
keybind = left=text:\x1b[D
keybind = right=text:\x1b[C

# Material 3 UI elements
unfocused-split-opacity = 0.7
unfocused-split-fill = #44464f

# Shell integration
shell-integration = detect
shell-integration-features = sudo,title
keybind = shift+enter=text:\n

# Dank color generation
theme = dankcolors
