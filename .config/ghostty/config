font-family = Inconsolata Nerd Font
font-size = 11
font-feature = -calt, -liga, -dlig

cursor-style-blink = false
cursor-text = #000000

window-padding-x = 4
window-padding-y = 2
window-padding-balance = true

# Allow alt + arrow keys for tmux movement.
keybind = alt+left=unbind
keybind = alt+right=unbind
keybind = alt+up=unbind
keybind = alt+down=unbind

# Load theme.
config-file = ?theme

# Load a custom config for overrides, ? silently fails if the file is missing.
config-file = ?config.local
