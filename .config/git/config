[core]
  editor = zed --wait
  pager = delta

[delta]
  navigate = true

[interactive]
  diffFilter = delta --color-only

[diff]
  tool = zed

[difftool "zed"]
  cmd = zed --wait --diff \"$LOCAL\" \"$REMOTE\"

[merge]
  tool = meld
  conflictStyle = zdiff3

[mergetool]
  keepBackup = false
  prompt = false

[mergetool "meld"]
  cmd = meld \"$LOCAL\" \"$BASE\" \"$REMOTE\" --output \"$MERGED\"

[include]
  path = ~/.config/git/config.local
