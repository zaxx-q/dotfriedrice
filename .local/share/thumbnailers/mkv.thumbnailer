# At some point in July 2026, I noticed .mkv files generated by OBS no longer
# had thumbnails get generated for them. This resolves that problem.
#
# I noticed /usr/share/thumbnailers/ffmpegthumbnailer.thumbnailer has no
# entry for video/matroska which is what this adds and is what Thunar is
# sending to Tumbler when it passes a message to D-Bus to generate a thumbnail.
[Thumbnailer Entry]
TryExec=ffmpegthumbnailer
Exec=ffmpegthumbnailer -i %i -o %o -s %s -f
MimeType=video/matroska;
